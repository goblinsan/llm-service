# Host path mounted to /data/models in the container.
MODELS_HOST_DIR=/data/models

# Host path mounted to /data/llm for runtime state and wrapper data.
LLM_STATE_DIR=/data/llm

# Directory inside the container scanned for GGUF models.
MODELS_DIR=/data/models/llm

# Path to the GGUF model file inside the container (mounted from /data/models on host)
MODEL_PATH=/data/models/llm/model.gguf

# Number of layers to offload to GPU. -1 = all layers (full GPU offload, recommended).
# Set to 0 to run entirely on CPU.
N_GPU_LAYERS=-1

# Context window size in tokens (default 4096).
# Larger values increase VRAM usage for the KV cache.
CTX_SIZE=4096

# Host port to publish the llm-service wrapper on (container always listens on 8080 internally).
HOST_PORT=5301

# Admin bearer token for model management endpoints (POST /api/models/download and POST /api/models/load).
# Leave empty to disable authentication (not recommended in production).
ADMIN_TOKEN=change-me-before-deploying

# Optional absolute path to llama-server inside the container. Leave empty to auto-detect.
LLAMA_BIN=

# Hard cap on max_tokens for each inference request.
# Requests that omit max_tokens or ask for more than this value are silently clamped.
# Lower values reduce peak VRAM pressure from the KV cache.
MAX_TOKENS=2048

# Seconds before an in-flight inference request is abandoned and a 504 is returned.
# Set higher if you regularly generate very long completions.
REQUEST_TIMEOUT=120

# Maximum number of inference requests that may run at the same time.
# 1 serialises requests (like the STT service) to avoid starving other GPU workloads.
MAX_CONCURRENT_REQUESTS=1
